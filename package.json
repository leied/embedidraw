{
  "name": "embedidraw",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run copy-assets && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name embedidraw",
    "copy-assets": "cp -r node_modules/@excalidraw/excalidraw/dist/excalidraw-assets public/"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "wrangler": "^3.101.0"
  }
}
