{
  "name": "embedidraw",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run copy-assets && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "copy-assets": "cp -r node_modules/@excalidraw/excalidraw/dist/excalidraw-assets public/"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@excalidraw/excalidraw": "^0.17.6",
    "@mui/material": "^9.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "wrangler": "^4.103.0"
  }
}
